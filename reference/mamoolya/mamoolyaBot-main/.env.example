TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=60000
OPENAI_FALLBACKS="gpt-4o-mini,gpt-3.5-turbo"
LLM_PROVIDER=legacy
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/free
PROMPT_CACHE_KEY=optional-static-key
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-70b-8192
CHAT_ID=your_chat_id
DB_PATH=chat.db
STATIC_WEB_PATH=/path/to/static/web/files
ADMIN_USER_ID=your_admin_user_id
SYNC_COMMANDS_ON_START=true
MAMULYA_DIALOGUE_STYLE=auto
MAMULYA_SUMMARY_TONE=balanced
MAMULYA_CONTEXT_DEPTH=6
