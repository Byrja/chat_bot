[Unit]
Description=MD4 Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/srv/openclaw-bus/chat_bot
EnvironmentFile=/srv/openclaw-bus/chat_bot/.env
ExecStart=/srv/openclaw-bus/chat_bot/run.sh
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
